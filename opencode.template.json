{
  "$schema": "https://opencode.ai/config.json",
  "model": "nvidia/qwen/qwen3-next-80b-a3b-thinking",
  "provider": {
    "nvidia": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "NVIDIA NIM (Qwen free tier — via local proxy)",
      "options": {
        "baseURL": "http://127.0.0.1:8889/v1"
      },
      "models": {
        "qwen/qwen3-coder-480b-a35b-instruct": {"name": "Qwen3 Coder 480B (A35B)"},
        "qwen/qwen3-next-80b-a3b-instruct":    {"name": "Qwen3 Next 80B (A3B) instruct"},
        "qwen/qwen3-next-80b-a3b-thinking": {
          "name": "Qwen3 Next 80B (A3B) thinking",
          "options": {
            "extraBody": {
              "chat_template_kwargs": { "enable_thinking": true }
            }
          }
        },
        "qwen/qwen3.5-122b-a10b":              {"name": "Qwen3.5 122B (A10B)"},
        "qwen/qwen3.5-397b-a17b": {
          "name": "Qwen3.5 397B (A17B) — default, thinking on",
          "options": {
            "extraBody": {
              "chat_template_kwargs": { "enable_thinking": true }
            }
          }
        },
        "qwen/qwen2.5-coder-32b-instruct":     {"name": "Qwen2.5 Coder 32B"}
      }
    }
  },
  "mcp": {
    "kaetram": {
      "type": "local",
      "command": [
        "__VENV_PYTHON__",
        "__PROJECT_DIR__/mcp_game_server.py"
      ],
      "enabled": true
    }
  }
}
