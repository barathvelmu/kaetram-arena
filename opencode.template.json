{
  "$schema": "https://opencode.ai/config.json",
  "model": "xai/grok-4-1-fast-reasoning",
  "provider": {
    "xai": {
      "npm": "@ai-sdk/xai",
      "name": "xAI Grok (direct — Grok 4.1 Fast hides reasoning, no proxy needed)",
      "options": {
        "baseURL": "https://api.x.ai/v1"
      },
      "models": {
        "grok-4-1-fast-reasoning":     {"name": "Grok 4.1 Fast (reasoning)"},
        "grok-4-1-fast-non-reasoning": {"name": "Grok 4.1 Fast (non-reasoning)"}
      }
    },
    "nvidia": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "NVIDIA NIM (Qwen free tier — via local proxy)",
      "options": {
        "baseURL": "http://127.0.0.1:8889/v1"
      },
      "models": {
        "qwen/qwen3-coder-480b-a35b-instruct": {"name": "Qwen3 Coder 480B (A35B)"},
        "qwen/qwen3-next-80b-a3b-instruct":    {"name": "Qwen3 Next 80B (A3B) instruct"},
        "qwen/qwen3-next-80b-a3b-thinking": {
          "name": "Qwen3 Next 80B (A3B) thinking",
          "options": {
            "extraBody": {
              "chat_template_kwargs": { "enable_thinking": true }
            }
          }
        },
        "qwen/qwen3.5-35b-a3b": {
          "name": "Qwen3.5 35B (A3B) thinking",
          "options": {
            "extraBody": {
              "chat_template_kwargs": { "enable_thinking": true }
            }
          }
        },
        "qwen/qwen3.5-122b-a10b":              {"name": "Qwen3.5 122B (A10B)"},
        "qwen/qwen3.5-397b-a17b": {
          "name": "Qwen3.5 397B (A17B) — flagship, thinking on",
          "options": {
            "extraBody": {
              "chat_template_kwargs": { "enable_thinking": true }
            }
          }
        },
        "qwen/qwen2.5-coder-32b-instruct":     {"name": "Qwen2.5 Coder 32B"}
      }
    },
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek V4 (via local SSE-rewriting proxy on :8890)",
      "options": {
        "baseURL": "http://127.0.0.1:8890/v1"
      },
      "models": {
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro (1.6T MoE / 49B active)",
          "reasoning": true,
          "interleaved": { "field": "reasoning_content" }
        },
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash (284B MoE / 13B active)",
          "reasoning": true,
          "interleaved": { "field": "reasoning_content" }
        }
      }
    }
  },
  "mcp": {
    "kaetram": {
      "type": "local",
      "command": [
        "__VENV_PYTHON__",
        "__PROJECT_DIR__/mcp_game_server.py"
      ],
      "enabled": true
    }
  }
}
